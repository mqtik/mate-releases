:[],"type":"text","url":"/docs/integrations/overview","content":"How MCP connectors work in Mate and what they enable."},"1019":{"id":"/docs/integrations/overview-1","page_id":"/docs/integrations/overview","type":"heading","tags":[],"url":"/docs/integrations/overview#what-is-mcp","content":"What is MCP?"},"1020":{"id":"/docs/integrations/overview-2","page_id":"/docs/integrations/overview","type":"heading","tags":[],"url":"/docs/integrations/overview#how-connectors-work-in-mate","content":"How connectors work in Mate"},"1021":{"id":"/docs/integrations/overview-3","page_id":"/docs/integrations/overview","type":"heading","tags":[],"url":"/docs/integrations/overview#what-connectors-enable","content":"What connectors enable"},"1022":{"id":"/docs/integrations/overview-4","page_id":"/docs/integrations/overview","type":"heading","tags":[],"url":"/docs/integrations/overview#transport-types","content":"Transport types"},"1023":{"id":"/docs/integrations/overview-5","page_id":"/docs/integrations/overview","type":"heading","tags":[],"url":"/docs/integrations/overview#next-steps","content":"Next steps"},"1024":{"id":"/docs/integrations/overview-6","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview","content":"Mate ships with a full library of integrations built on the &#x2A;*Model Context Protocol (MCP)**. These connectors let your AI agents interact with external services — GitHub, Slack, databases, cloud providers, and more — directly from agent chat."},"1025":{"id":"/docs/integrations/overview-7","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#what-is-mcp","content":"The Model Context Protocol is an open standard for connecting AI assistants to external tools. Each MCP connector runs as a local process that speaks a standardized protocol over stdin/stdout. The connector exposes \"tools\" that the AI agent can call — like creating a GitHub issue, querying a database, or sending a Slack message."},"1026":{"id":"/docs/integrations/overview-8","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#how-connectors-work-in-mate","content":"When you enable a connector in Mate:"},"1027":{"id":"/docs/integrations/overview-9","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#how-connectors-work-in-mate","content":"Mate stores your credentials locally (API keys, tokens) in encrypted storage on your device"},"1028":{"id":"/docs/integrations/overview-10","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#how-connectors-work-in-mate","content":"When you start an agent chat, Mate spawns the connector process and passes it to the CLI as an MCP server"},"1029":{"id":"/docs/integrations/overview-11","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#how-connectors-work-in-mate","content":"The AI agent discovers the connector's tools and can call them during the conversation"},"1030":{"id":"/docs/integrations/overview-12","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#how-connectors-work-in-mate","content":"The connector process runs locally on your machine — credentials never leave your device"},"1031":{"id":"/docs/integrations/overview-13","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#how-connectors-work-in-mate","content":"Mate bundles its own Node.js runtime, so most connectors work out of the box without you needing to install Node.js separately. The bundled runtime handles `npx` commands that connectors use to start."},"1032":{"id":"/docs/integrations/overview-14","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#what-connectors-enable","content":"With connectors, your AI agent can:"},"1033":{"id":"/docs/integrations/overview-15","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#what-connectors-enable","content":"**Read and write code** on GitHub, GitLab, or Bitbucket"},"1034":{"id":"/docs/integrations/overview-16","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#what-connectors-enable","content":"**Manage projects** in Linear, Jira, Asana, or Trello"},"1035":{"id":"/docs/integrations/overview-17","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#what-connectors-enable","content":"**Query databases** like Postgres, MySQL, MongoDB, or Redis"},"1036":{"id":"/docs/integrations/overview-18","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#what-connectors-enable","content":"**Search the web** via Brave Search, Exa, or Tavily"},"1037":{"id":"/docs/integrations/overview-19","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#what-connectors-enable","content":"**Send messages** on Slack, Discord, or Telegram"},"1038":{"id":"/docs/integrations/overview-20","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#what-connectors-enable","content":"**Manage infrastructure** on AWS, Cloudflare, Vercel, or Kubernetes"},"1039":{"id":"/docs/integrations/overview-21","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#what-connectors-enable","content":"**Generate images** with DALL-E, Stable Diffusion, or fal.ai"},"1040":{"id":"/docs/integrations/overview-22","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#what-connectors-enable","content":"And much more — see the full connector list"},"1041":{"id":"/docs/integrations/overview-23","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#transport-types","content":"Most connectors use **stdio** transport — Mate spawns a local process and communicates over stdin/stdout. A few built-in connectors (like Mate Canvas) are handled directly by the app without spawning a separate process."},"1042":{"id":"/docs/integrations/overview-24","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#next-steps","content":"Set up a connector — step-by-step guide"},"1043":{"id":"/docs/integrations/overview-25","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#next-steps","content":"Browse all connectors — full list by category"},"1044":{"id":"/docs/integrations/overview-26","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#next-steps","content":"Claude Code integration — detailed guide for the most popular CLI"},"1045":{"id":"/docs/integrations/overview-27","page_id":"/docs/integrations/overview","tags":[],"type":"text","url":"/docs/integrations/overview#next-steps","content":"Custom connectors — add your own MCP servers"},"1046":{"id":"/docs/integrations/skills","page_id":"/docs/integrations/skills","type":"page","content":"Skills","breadcrumbs":["Docs","Integrations"],"tags":[],"url":"/docs/integrations/skills"},"1047":{"id":"/docs/integrations/skills-0","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills","content":"Extend your AI agents with installable skills."},"1048":{"id":"/docs/integrations/skills-1","page_id":"/docs/integrations/skills","type":"heading","tags":[],"url":"/docs/integrations/skills#how-skills-work","content":"How skills work"},"1049":{"id":"/docs/integrations/skills-2","page_id":"/docs/integrations/skills","type":"heading","tags":[],"url":"/docs/integrations/skills#browsing-the-marketplace","content":"Browsing the marketplace"},"1050":{"id":"/docs/integrations/skills-3","page_id":"/docs/integrations/skills","type":"heading","tags":[],"url":"/docs/integrations/skills#open-settings","content":"Open Settings"},"1051":{"id":"/docs/integrations/skills-4","page_id":"/docs/integrations/skills","type":"heading","tags":[],"url":"/docs/integrations/skills#navigate-to-skills","content":"Navigate to Skills"},"1052":{"id":"/docs/integrations/skills-5","page_id":"/docs/integrations/skills","type":"heading","tags":[],"url":"/docs/integrations/skills#browse-and-preview","content":"Browse and preview"},"1053":{"id":"/docs/integrations/skills-6","page_id":"/docs/integrations/skills","type":"heading","tags":[],"url":"/docs/integrations/skills#install","content":"Install"},"1054":{"id":"/docs/integrations/skills-7","page_id":"/docs/integrations/skills","type":"heading","tags":[],"url":"/docs/integrations/skills#using-skills-in-chat","content":"Using skills in chat"},"1055":{"id":"/docs/integrations/skills-8","page_id":"/docs/integrations/skills","type":"heading","tags":[],"url":"/docs/integrations/skills#skill-structure","content":"Skill structure"},"1056":{"id":"/docs/integrations/skills-9","page_id":"/docs/integrations/skills","type":"heading","tags":[],"url":"/docs/integrations/skills#managing-installed-skills","content":"Managing installed skills"},"1057":{"id":"/docs/integrations/skills-10","page_id":"/docs/integrations/skills","type":"heading","tags":[],"url":"/docs/integrations/skills#custom-skills","content":"Custom skills"},"1058":{"id":"/docs/integrations/skills-11","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills","content":"Skills are reusable prompt templates and commands that you install into your AI coding CLIs. They add slash commands, specialized behaviors, and domain-specific knowledge to your agent chat sessions — like plugins for your AI assistant."},"1059":{"id":"/docs/integrations/skills-12","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills","content":"For example, a \"code review\" skill might add a `/review` command that instructs the agent to follow a specific review checklist. A \"testing\" skill might add `/test-spec` that generates tests from a specification file. Skills encode best practices into repeatable, shareable commands."},"1060":{"id":"/docs/integrations/skills-13","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#how-skills-work","content":"When you install a skill, Mate places it in the appropriate directory for each CLI:"},"1061":{"id":"/docs/integrations/skills-14","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#how-skills-work","content":"CLI"},"1062":{"id":"/docs/integrations/skills-15","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#how-skills-work","content":"Skill directory"},"1063":{"id":"/docs/integrations/skills-16","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#how-skills-work","content":"Claude Code"},"1064":{"id":"/docs/integrations/skills-17","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#how-skills-work","content":"`.claude/skills/`"},"1065":{"id":"/docs/integrations/skills-18","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#how-skills-work","content":"Codex"},"1066":{"id":"/docs/integrations/skills-19","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#how-skills-work","content":"`.codex/skills/`"},"1067":{"id":"/docs/integrations/skills-20","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#how-skills-work","content":"Copilot"},"1068":{"id":"/docs/integrations/skills-21","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#how-skills-work","content":"`.copilot/skills/`"},"1069":{"id":"/docs/integrations/skills-22","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#how-skills-work","content":"Shared"},"1070":{"id":"/docs/integrations/skills-23","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#how-skills-work","content":"`.mate/skills/`"},"1071":{"id":"/docs/integrations/skills-24","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#how-skills-work","content":"Skills installed through Mate are symlinked across CLI directories, so a single skill works with all your agents without duplication. Install it once, use it everywhere."},"1072":{"id":"/docs/integrations/skills-25","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#how-skills-work","content":"Each skill is a markdown file that contains the prompt template and metadata the CLI uses to register it as a slash command."},"1073":{"id":"/docs/integrations/skills-26","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#open-settings","content":"Go to the **Settings** tab in Mate."},"1074":{"id":"/docs/integrations/skills-27","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#navigate-to-skills","content":"Find the **Skills** section. This shows the marketplace — a browsable list of available skills organized by category."},"1075":{"id":"/docs/integrations/skills-28","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#browse-and-preview","content":"Each skill shows its name, description, and what slash commands it adds. You can preview the full prompt template before installing."},"1076":{"id":"/docs/integrations/skills-29","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#install","content":"Tap **Install** on any skill. Mate downloads it and symlinks it into the appropriate CLI directories. The skill is immediately available in your next agent chat session."},"1077":{"id":"/docs/integrations/skills-30","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#using-skills-in-chat","content":"Once installed, skills appear as slash commands in agent chat. Type `/` in the composer to see available commands. Select one to invoke the skill — the prompt template is sent to the agent, which follows its instructions."},"1078":{"id":"/docs/integrations/skills-31","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#using-skills-in-chat","content":"Some skills are fire-and-forget (run a single task), while others are interactive (the agent asks follow-up questions based on the skill's template)."},"1079":{"id":"/docs/integrations/skills-32","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#skill-structure","content":"A skill is a markdown file with frontmatter metadata:"},"1080":{"id":"/docs/integrations/skills-33","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#skill-structure","content":"The CLI reads the frontmatter to register the slash command, and uses the body as the prompt template when invoked."},"1081":{"id":"/docs/integrations/skills-34","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#managing-installed-skills","content":"In the Skills section of Settings, you can see all installed skills and:"},"1082":{"id":"/docs/integrations/skills-35","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#managing-installed-skills","content":"**Uninstall** a skill to remove it from all CLI directories"},"1083":{"id":"/docs/integrations/skills-36","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#managing-installed-skills","content":"**Update** a skill if a newer version is available in the marketplace"},"1084":{"id":"/docs/integrations/skills-37","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#managing-installed-skills","content":"**View details** to see the full prompt template"},"1085":{"id":"/docs/integrations/skills-38","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#custom-skills","content":"You can create your own skills by placing markdown files directly in `.mate/skills/` or the CLI-specific skill directories. Custom skills follow the same format as marketplace skills and appear alongside them in the slash command list."},"1086":{"id":"/docs/integrations/skills-39","page_id":"/docs/integrations/skills","tags":[],"type":"text","url":"/docs/integrations/skills#custom-skills","content":"This is useful for team-specific workflows — write a skill once, share the file, and everyone on the team gets the same commands."}},"count":1086},"sorting":{"language":"english","sortableProperties":["content","page_id","type","url"],"sortablePropertiesWithTypes":{"content":"string","page_id":"string","type":"string","url":"string"},"sorts":{"content":{"docs":{"1":1020,"2":165,"3":747,"4":1021,"5":485,"6":593,"7":943,"8":369,"9":695,"10":247,"11":296,"12":89,"13":12,"14":32,"15":73,"16":117,"17":112,"18":70,"19":22,"20":51,"21":109,"22":1080,"23":178,"24":246,"25":867,"26":219,"27":859,"28":964,"29":961,"30":217,"31":392,"32":318,"33":447,"34":771,"35":581,"36":242,"37":425,"38":844,"39":616,"40":755,"41":951,"42":182,"43":266,"44":640,"45":483,"46":256,"47":1065,"48":853,"49":283,"50":680,"51":851,"52":320,"53":681,"54":852,"55":262,"56":379,"57":267,"58":631,"59":257,"60":479,"61":284,"62":286,"63":321,"64":475,"65":805,"66":273,"67":254,"68":977,"69":904,"70":1037,"71":78,"72":88,"73":92,"74":33,"75":963,"76":850,"77":2,"78":1,"79":80,"80":445,"81":264,"82":378,"83":25,"84":47,"85":86,"86":316,"87":315,"88":186,"89"
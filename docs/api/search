,"url":"/docs#what-can-you-do-with-mate","content":"**Transfer files** between devices with drag-and-drop simplicity"},"17":{"id":"/docs-15","page_id":"/docs","tags":[],"type":"text","url":"/docs#what-can-you-do-with-mate","content":"**Talk instead of type** with built-in voice input supporting four STT engines including offline Whisper"},"18":{"id":"/docs-16","page_id":"/docs","tags":[],"type":"text","url":"/docs#what-can-you-do-with-mate","content":"**Orchestrate agents** by running multiple AI sessions in parallel across your projects"},"19":{"id":"/docs-17","page_id":"/docs","tags":[],"type":"text","url":"/docs#what-can-you-do-with-mate","content":"**Connect your tools** through MCP connectors — databases, APIs, cloud services, and more"},"20":{"id":"/docs-18","page_id":"/docs","tags":[],"type":"text","url":"/docs#what-can-you-do-with-mate","content":"**Install skills** from the marketplace to add slash commands and specialized workflows to your agents"},"21":{"id":"/docs-19","page_id":"/docs","tags":[],"type":"text","url":"/docs#what-can-you-do-with-mate","content":"**Sync across devices** — pair your phone, tablet, or another computer and access everything from anywhere on your network"},"22":{"id":"/docs-20","page_id":"/docs","tags":[],"type":"text","url":"/docs#how-it-works","content":"Your desktop runs Mate as the server. It owns all session state: terminals, projects, agent chats, and files. Your phone (or any other device on the same network) pairs with it and acts as a live mirror — you see and interact with the same sessions, in real time, from anywhere on your local network. No cloud. No accounts. Just your devices talking directly to each other."},"23":{"id":"/docs/features/agent-chat","page_id":"/docs/features/agent-chat","type":"page","content":"Agent Chat","breadcrumbs":["Docs","Features"],"tags":[],"url":"/docs/features/agent-chat"},"24":{"id":"/docs/features/agent-chat-0","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat","content":"Chat with AI coding agents like Claude Code, Codex, and Copilot inside Mate."},"25":{"id":"/docs/features/agent-chat-1","page_id":"/docs/features/agent-chat","type":"heading","tags":[],"url":"/docs/features/agent-chat#supported-clis","content":"Supported CLIs"},"26":{"id":"/docs/features/agent-chat-2","page_id":"/docs/features/agent-chat","type":"heading","tags":[],"url":"/docs/features/agent-chat#available-models","content":"Available models"},"27":{"id":"/docs/features/agent-chat-3","page_id":"/docs/features/agent-chat","type":"heading","tags":[],"url":"/docs/features/agent-chat#starting-a-chat","content":"Starting a chat"},"28":{"id":"/docs/features/agent-chat-4","page_id":"/docs/features/agent-chat","type":"heading","tags":[],"url":"/docs/features/agent-chat#tool-use","content":"Tool use"},"29":{"id":"/docs/features/agent-chat-5","page_id":"/docs/features/agent-chat","type":"heading","tags":[],"url":"/docs/features/agent-chat#tool-approval","content":"Tool approval"},"30":{"id":"/docs/features/agent-chat-6","page_id":"/docs/features/agent-chat","type":"heading","tags":[],"url":"/docs/features/agent-chat#auto-approval-and-permission-modes","content":"Auto-approval and permission modes"},"31":{"id":"/docs/features/agent-chat-7","page_id":"/docs/features/agent-chat","type":"heading","tags":[],"url":"/docs/features/agent-chat#effort-level","content":"Effort level"},"32":{"id":"/docs/features/agent-chat-8","page_id":"/docs/features/agent-chat","type":"heading","tags":[],"url":"/docs/features/agent-chat#conversations","content":"Conversations"},"33":{"id":"/docs/features/agent-chat-9","page_id":"/docs/features/agent-chat","type":"heading","tags":[],"url":"/docs/features/agent-chat#forking","content":"Forking"},"34":{"id":"/docs/features/agent-chat-10","page_id":"/docs/features/agent-chat","type":"heading","tags":[],"url":"/docs/features/agent-chat#rich-content","content":"Rich content"},"35":{"id":"/docs/features/agent-chat-11","page_id":"/docs/features/agent-chat","type":"heading","tags":[],"url":"/docs/features/agent-chat#markdown-rendering","content":"Markdown rendering"},"36":{"id":"/docs/features/agent-chat-12","page_id":"/docs/features/agent-chat","type":"heading","tags":[],"url":"/docs/features/agent-chat#canvas-artifacts","content":"Canvas artifacts"},"37":{"id":"/docs/features/agent-chat-13","page_id":"/docs/features/agent-chat","type":"heading","tags":[],"url":"/docs/features/agent-chat#file-and-image-attachments","content":"File and image attachments"},"38":{"id":"/docs/features/agent-chat-14","page_id":"/docs/features/agent-chat","type":"heading","tags":[],"url":"/docs/features/agent-chat#slash-commands","content":"Slash commands"},"39":{"id":"/docs/features/agent-chat-15","page_id":"/docs/features/agent-chat","type":"heading","tags":[],"url":"/docs/features/agent-chat#mcp-connectors-in-agent-chat","content":"MCP connectors in agent chat"},"40":{"id":"/docs/features/agent-chat-16","page_id":"/docs/features/agent-chat","type":"heading","tags":[],"url":"/docs/features/agent-chat#remote-agent-chat","content":"Remote agent chat"},"41":{"id":"/docs/features/agent-chat-17","page_id":"/docs/features/agent-chat","type":"heading","tags":[],"url":"/docs/features/agent-chat#tips","content":"Tips"},"42":{"id":"/docs/features/agent-chat-18","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat","content":"Agent Chat lets you work with AI coding assistants directly inside Mate. Instead of switching between your terminal and a separate chat window, the agent runs alongside your other sessions — reading your files, executing commands, and making edits, all visible in real time."},"43":{"id":"/docs/features/agent-chat-19","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#supported-clis","content":"CLI"},"44":{"id":"/docs/features/agent-chat-20","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#supported-clis","content":"Multi-turn"},"45":{"id":"/docs/features/agent-chat-21","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#supported-clis","content":"How it connects"},"46":{"id":"/docs/features/agent-chat-22","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#supported-clis","content":"Claude Code"},"47":{"id":"/docs/features/agent-chat-23","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#supported-clis","content":"Yes (long-lived stdin)"},"48":{"id":"/docs/features/agent-chat-24","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#supported-clis","content":"Spawns process, sends messages via `--input-format stream-json`"},"49":{"id":"/docs/features/agent-chat-25","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#supported-clis","content":"Codex"},"50":{"id":"/docs/features/agent-chat-26","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#supported-clis","content":"One-shot"},"51":{"id":"/docs/features/agent-chat-27","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#supported-clis","content":"Spawns a new process per message"},"52":{"id":"/docs/features/agent-chat-28","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#supported-clis","content":"Copilot"},"53":{"id":"/docs/features/agent-chat-29","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#supported-clis","content":"One-shot"},"54":{"id":"/docs/features/agent-chat-30","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#supported-clis","content":"Spawns a new process per message"},"55":{"id":"/docs/features/agent-chat-31","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#supported-clis","content":"Claude Code keeps a persistent process running, so follow-up messages are instant. Codex and Copilot spawn fresh processes for each message, which takes a few seconds."},"56":{"id":"/docs/features/agent-chat-32","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#available-models","content":"Each CLI gives you access to different models:"},"57":{"id":"/docs/features/agent-chat-33","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#available-models","content":"CLI"},"58":{"id":"/docs/features/agent-chat-34","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#available-models","content":"Models"},"59":{"id":"/docs/features/agent-chat-35","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#available-models","content":"Claude Code"},"60":{"id":"/docs/features/agent-chat-36","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#available-models","content":"Haiku 4.5, Sonnet 4.6, Opus 4.6"},"61":{"id":"/docs/features/agent-chat-37","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#available-models","content":"Codex"},"62":{"id":"/docs/features/agent-chat-38","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#available-models","content":"Codex Mini, GPT-5.2 Codex, o4-mini, o3"},"63":{"id":"/docs/features/agent-chat-39","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#available-models","content":"Copilot"},"64":{"id":"/docs/features/agent-chat-40","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#available-models","content":"GPT-4o, Claude 3.5 Sonnet, o3-mini"},"65":{"id":"/docs/features/agent-chat-41","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#available-models","content":"Select your preferred model from the dropdown in the chat header. The model affects response quality, speed, and cost."},"66":{"id":"/docs/features/agent-chat-42","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#starting-a-chat","content":"Click &#x2A;*+** in the tab bar and select **Agent Chat**"},"67":{"id":"/docs/features/agent-chat-43","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#starting-a-chat","content":"Choose your CLI (Claude Code, Codex, or Copilot) from the dropdown"},"68":{"id":"/docs/features/agent-chat-44","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#starting-a-chat","content":"Type your message and press Enter"},"69":{"id":"/docs/features/agent-chat-45","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#starting-a-chat","content":"The agent streams its response in real time. You will see text output as it is generated, and tool use appears as interactive chips showing what the agent is doing."},"70":{"id":"/docs/features/agent-chat-46","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#tool-use","content":"When the agent calls tools — reading files, running commands, searching code — Mate shows each tool invocation with meaningful context:"},"71":{"id":"/docs/features/agent-chat-47","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#tool-use","content":"**Read file** shows the filename being read"},"72":{"id":"/docs/features/agent-chat-48","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#tool-use","content":"**Run command** shows the actual shell command"},"73":{"id":"/docs/features/agent-chat-49","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#tool-use","content":"**Search** shows the query being searched"},"74":{"id":"/docs/features/agent-chat-50","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#tool-use","content":"**Edit file** shows which file is being modified"},"75":{"id":"/docs/features/agent-chat-51","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#tool-use","content":"Tool calls that modify files (edits, writes) are highlighted so you can review what changed. Mate generates inline diffs for file modifications."},"76":{"id":"/docs/features/agent-chat-52","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#tool-approval","content":"Some tools require your approval before the agent can execute them. When the agent wants to run a potentially destructive action (like writing a file or running a shell command), Mate shows a permission prompt. You can:"},"77":{"id":"/docs/features/agent-chat-53","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#tool-approval","content":"**Approve** the individual tool call"},"78":{"id":"/docs/features/agent-chat-54","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#tool-approval","content":"**Approve all** for that tool type during the session"},"79":{"id":"/docs/features/agent-chat-55","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#tool-approval","content":"**Reject** to deny the action"},"80":{"id":"/docs/features/agent-chat-56","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#auto-approval-and-permission-modes","content":"For trusted workflows, you can configure auto-approval in the chat settings. This lets the agent run tools without asking — useful when you are watching the output and want a faster feedback loop. You can set permission modes per tool category (e.g., always approve file reads, always ask before shell commands)."},"81":{"id":"/docs/features/agent-chat-57","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#effort-level","content":"Claude Code supports an effort setting that controls how thorough the agent is. Lower effort means faster, more concise responses. Higher effort means the agent spends more time thinking, reading more files, and producing more detailed output. Adjust this in the chat header."},"82":{"id":"/docs/features/agent-chat-58","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#conversations","content":"Each agent chat is a persistent conversation. You can:"},"83":{"id":"/docs/features/agent-chat-59","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#conversations","content":"**Continue** a conversation by sending more messages"},"84":{"id":"/docs/features/agent-chat-60","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#conversations","content":"**Fork** a conversation to branch off from a specific point — useful when you want to try a different approach without losing the original thread"},"85":{"id":"/docs/features/agent-chat-61","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#conversations","content":"**Resume** a previous conversation from the sidebar"},"86":{"id":"/docs/features/agent-chat-62","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#conversations","content":"Conversation history is stored locally on your desktop. Nothing is sent to any cloud service beyond what the underlying CLI itself sends to its API."},"87":{"id":"/docs/features/agent-chat-63","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#forking","content":"Conversation forking creates a new conversation that starts with the same history up to the point you forked. The original conversation is untouched. This lets you explore \"what if\" scenarios — try a different approach, and if it doesn't work out, go back to the original."},"88":{"id":"/docs/features/agent-chat-64","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#markdown-rendering","content":"Agent responses render full Markdown with syntax highlighting for code blocks, tables, lists, and inline formatting. Code blocks show the language label and can be copied with one click."},"89":{"id":"/docs/features/agent-chat-65","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#canvas-artifacts","content":"When an agent produces self-contained HTML/JS/CSS, Mate can display it in a Canvas panel alongside the chat. This is useful for visual content — charts, diagrams, interactive prototypes — that the agent generates during the conversation."},"90":{"id":"/docs/features/agent-chat-66","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#file-and-image-attachments","content":"Drag and drop files or images into the composer, or paste them from your clipboard. The agent receives the file content as part of the message context. This works with code files, screenshots, logs, or any text-based content you want the agent to see."},"91":{"id":"/docs/features/agent-chat-67","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#slash-commands","content":"Type `/` in the composer to see available slash commands. These come from installed skills and built-in commands. Slash commands let you trigger specific workflows without typing out full prompts."},"92":{"id":"/docs/features/agent-chat-68","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#mcp-connectors-in-agent-chat","content":"If you have MCP connectors configured, the agent can use them as tools. For example, with the GitHub connector enabled, Claude Code can create pull requests, read issues, and manage repositories directly from chat."},"93":{"id":"/docs/features/agent-chat-69","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#mcp-connectors-in-agent-chat","content":"Mate generates an MCP config file that the CLI reads at startup, so all your connected integrations are available to the agent automatically."},"94":{"id":"/docs/features/agent-chat-70","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#remote-agent-chat","content":"Agent chat works from paired remote devices. When you select a remote device in the sidebar, you see its running agent chat sessions and can interact with them. The CLI process runs on the desktop — the remote device sends input and receives streamed output over the network."},"95":{"id":"/docs/features/agent-chat-71","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#tips","content":"Long-running agent tasks keep working even if you switch to another tab"},"96":{"id":"/docs/features/agent-chat-72","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#tips","content":"Use conversation forking when you want to try a different approach without losing the original thread"},"97":{"id":"/docs/features/agent-chat-73","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#tips","content":"The agent respects your project's working directory when running commands"},"98":{"id":"/docs/features/agent-chat-74","page_id":"/docs/features/agent-chat","tags":[],"type":"text","url":"/docs/features/agent-chat#tips","content":"Use voice input to dictate prompts instead of typing"},"99":{"id":"/docs/features/file-transfer","page_id":"/docs/features/file-transfer","type":"page","content":"File Transfer","breadcrumbs":["Docs","Features"],"tags":[],"url":"/docs/features/file-transfer"},"100":{"id":"/docs/features/file-transfer-0","page_id":"/docs/features/file-transfer","tags":[],"type":"text","url":"/docs/features/file-transfer","content":"Send and receive files between paired devices."},"101":{"id":"/docs/features/file-transfer-1","page_id":"/docs/features/file-transfer","type":"heading","tags":[],"url":"/docs/features/file-transfer#sending-files","content":"Sending files"},"102":{"id":"/docs/features/file-transfer-2","page_id":"/docs/features/file-transfer","type":"heading","tags":[],"url":"/docs/features/file-transfer#open-the-send-tab","content":"Open the Send tab"},"103":{"id":"/docs/features/file-transfer-3","page_id":"/docs/features/file-transfer","type":"heading","tags":[],"url":"/docs/features/file-transfer#select-files","content":"Select files"},"104":{"id":"/docs/features/file-transfer-4","page_id":"/docs/features/file-transfer","type":"heading","tags":[],"url":"/docs/features/file-transfer#pick-a-destination","content":"Pick a destination"},"105":{"id":"/docs/features/file-transfer-5","page_id":"/docs/features/file-transfer","type":"heading","tags":[],"url":"/docs/features/file-transfer#send","content":"Send"},"106":{"id":"/docs/features/file-transfer-6","page_id":"/docs/features/file-transfer","type":"heading","tags":[],"url":"/docs/features/file-transfer#receiving-files","content":"Receiving files"},"107":{"id":"/docs/features/file-transfer-7","page_id":"/docs/features/file-transfer","type":"heading","tags":[],"url":"/docs/features/file-transfer#how-it-works","content":"How it works"},"108":{"id":"/docs/features/file-transfer-8","page_id":"/docs/features/file-transfer","type":"heading","tags":[],"url":"/docs/features/file-transfer#supported-file-types","content":"Supported file types"},"109":{"id":"/docs/features/file-transfer-9","page_id":"/docs/features/file-transfer","tags":[],"type":"text","url":"/docs/features/file-transfer","content":"Mate includes built-in file transfer between paired devices. Send files from your desktop to your phone, or receive files from your phone to your desktop — no third-party apps, cloud services, or cables needed."},"110":{"id":"/docs/features/file-transfer-10","page_id":"/docs/features/file-transfer","tags":[],"type":"text","url":"/docs/features/file-transfer#open-the-send-tab","content":"Navigate to the send interface in Mate."},"111":{"id":"/docs/features/file-transfer-11","page_id":"/docs/features/file-transfer","tags":[],"type":"text","url":"/docs/features/file-transfer#select-files","content":"Choose one or more files from your device. You can select multiple files at once."},"112":{"id":"/docs/features/file-transfer-12","page_id":"/docs/features/file-transfer","tags":[],"type":"text","url":"/docs/features/file-transfer#pick-a-destination","content":"Select the paired device you want to send to from the device list."},"113":{"id":"/docs/features/file-transfer-13","page_id":"/docs/features/file-transfer","tags":[],"type":"text","url":"/docs/features/file-transfer#send","content":"The files transfer directly over your local network. Large files transfer quickly since there is no cloud relay — data goes straight from device to device."},"114":{"id":"/docs/features/file-transfer-14","page_id":"/docs/features/file-transfer","tags":[],"type":"text","url":"/docs/features/file-transfer#receiving-files","content":"When a paired device sends you files, Mate notifies you and shows the incoming transfer. Received files are saved to your configured download location."},"115":{"id":"/docs/features/file-transfer-15","page_id":"/docs/features/file-transfer","tags":[],"type":"text","url":"/docs/features/file-transfer#how-it-works","content":"File transfers use the same direct TCP connection as all other Mate features. Files travel directly between devices on your local network with no intermediate server. Transfer speeds are limited only by your local network bandwidth — typically much faster than cloud-based alternatives."},"116":{"id":"/docs/features/file-transfer-16","page_id":"/docs/features/file-transfer","tags":[],"type":"text","url":"/docs/features/file-transfer#how-it-works","content":"File transfer works between any two paired devices: desktop to phone, phone to desktop, or desktop to desktop."},"117":{"id":"/docs/features/file-transfer-17","page_id":"/docs/features/file-transfer","tags":[],"type":"text","url":"/docs/features/file-transfer#supported-file-types","content":"Any file type is supported. There are no restrictions on what you can send — documents, images, videos, code archives, binaries, or anything else."},"118":{"id":"/docs/features/ide","page_id":"/docs/features/ide","type":"page","content":"IDE","breadcrumbs":["Docs","Features"],"tags":[],"url":"/docs/features/ide"},"119":{"id":"/docs/features/ide-0","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide","content":"Built-in multi-file editor with file tree, git integration, and syntax highlighting."},"120":{"id":"/docs/features/ide-1","page_id":"/docs/features/ide","type":"heading","tags":[],"url":"/docs/features/ide#opening-the-ide","content":"Opening the IDE"},"121":{"id":"/docs/features/ide-2","page_id":"/docs/features/ide","type":"heading","tags":[],"url":"/docs/features/ide#file-tree","content":"File tree"},"122":{"id":"/docs/features/ide-3","page_id":"/docs/features/ide","type":"heading","tags":[],"url":"/docs/features/ide#editor","content":"Editor"},"123":{"id":"/docs/features/ide-4","page_id":"/docs/features/ide","type":"heading","tags":[],"url":"/docs/features/ide#single-file-editor","content":"Single-file editor"},"124":{"id":"/docs/features/ide-5","page_id":"/docs/features/ide","type":"heading","tags":[],"url":"/docs/features/ide#remote-editing","content":"Remote editing"},"125":{"id":"/docs/features/ide-6","page_id":"/docs/features/ide","type":"heading","tags":[],"url":"/docs/features/ide#file-browser","content":"File browser"},"126":{"id":"/docs/features/ide-7","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide","content":"Mate includes a built-in IDE for editing code without leaving the app. It is not a replacement for VS Code or JetBrains — it is a lightweight, always-available editor that is especially useful when you are working remotely from your phone or tablet."},"127":{"id":"/docs/features/ide-8","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#opening-the-ide","content":"Click &#x2A;*+** in the tab bar"},"128":{"id":"/docs/features/ide-9","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#opening-the-ide","content":"Select **IDE**"},"129":{"id":"/docs/features/ide-10","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#opening-the-ide","content":"Choose a folder to open"},"130":{"id":"/docs/features/ide-11","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#opening-the-ide","content":"The IDE shows a file tree on the left and an editor pane on the right. Click any file to open it."},"131":{"id":"/docs/features/ide-12","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#file-tree","content":"The file tree is git-aware. It uses `git ls-files` to list tracked files, which means it automatically respects your `.gitignore` and skips build artifacts, `node_modules`, and other ignored directories. For non-git projects, it falls back to a standard directory listing."},"132":{"id":"/docs/features/ide-13","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#file-tree","content":"You can:"},"133":{"id":"/docs/features/ide-14","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#file-tree","content":"Navigate folders by expanding/collapsing them"},"134":{"id":"/docs/features/ide-15","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#file-tree","content":"Open files by clicking"},"135":{"id":"/docs/features/ide-16","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#file-tree","content":"Search files by name using the search bar at the top of the tree"},"136":{"id":"/docs/features/ide-17","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#editor","content":"The editor supports syntax highlighting for 100+ languages through the re\\_editor package. Features include:"},"137":{"id":"/docs/features/ide-18","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#editor","content":"Syntax highlighting with language auto-detection based on file extension"},"138":{"id":"/docs/features/ide-19","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#editor","content":"Line numbers"},"139":{"id":"/docs/features/ide-20","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#editor","content":"Find and replace"},"140":{"id":"/docs/features/ide-21","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#editor","content":"Undo/redo"},"141":{"id":"/docs/features/ide-22","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#editor","content":"Standard keyboard shortcuts for editing"},"142":{"id":"/docs/features/ide-23","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#editor","content":"The IDE is designed for quick edits and code review, not as a full development environment. For heavy editing sessions, pair it with your preferred desktop editor and use Mate's IDE for on-the-go changes."},"143":{"id":"/docs/features/ide-24","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#single-file-editor","content":"If you just need to edit one file without a full project tree, use the **Editor** tab type instead. It opens a single file in an editor with the same syntax highlighting and editing features."},"144":{"id":"/docs/features/ide-25","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#remote-editing","content":"The IDE works from paired remote devices. When you open an IDE tab on a remote session, you are browsing and editing files on the desktop. Changes are saved directly to the desktop's filesystem."},"145":{"id":"/docs/features/ide-26","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#remote-editing","content":"This is particularly useful for:"},"146":{"id":"/docs/features/ide-27","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#remote-editing","content":"Quick fixes from your phone while away from your desk"},"147":{"id":"/docs/features/ide-28","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#remote-editing","content":"Reviewing code that an AI agent just modified"},"148":{"id":"/docs/features/ide-29","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#remote-editing","content":"Editing configuration files on a remote machine"},"149":{"id":"/docs/features/ide-30","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#file-browser","content":"The file browser modal lets you navigate your filesystem to find files or folders. It supports:"},"150":{"id":"/docs/features/ide-31","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#file-browser","content":"Breadcrumb navigation"},"151":{"id":"/docs/features/ide-32","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#file-browser","content":"Quick search with fuzzy matching"},"152":{"id":"/docs/features/ide-33","page_id":"/docs/features/ide","tags":[],"type":"text","url":"/docs/features/ide#file-browser","content":"Git-aware file listing that filters out ignored files"},"153":{"id":"/docs/features/orchestrator","page_id":"/docs/features/orchestrator","type":"page","content":"Orchestrator","breadcrumbs":["Docs","Features"],"tags":[],"url":"/docs/features/orchestrator"},"154":{"id":"/docs/features/orchestrator-0","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator","content":"Run multiple AI agents in parallel with the multi-agent orchestrator."},"155":{"id":"/docs/features/orchestrator-1","page_id":"/docs/features/orchestrator","type":"heading","tags":[],"url":"/docs/features/orchestrator#how-it-works","content":"How it works"},"156":{"id":"/docs/features/orchestrator-2","page_id":"/docs/features/orchestrator","type":"heading","tags":[],"url":"/docs/features/orchestrator#use-cases","content":"Use cases"},"157":{"id":"/docs/features/orchestrator-3","page_id":"/docs/features/orchestrator","type":"heading","tags":[],"url":"/docs/features/orchestrator#creating-a-run","content":"Creating a run"},"158":{"id":"/docs/features/orchestrator-4","page_id":"/docs/features/orchestrator","type":"heading","tags":[],"url":"/docs/features/orchestrator#open-the-orchestrator","content":"Open the Orchestrator"},"159":{"id":"/docs/features/orchestrator-5","page_id":"/docs/features/orchestrator","type":"heading","tags":[],"url":"/docs/features/orchestrator#define-your-tasks","content":"Define your tasks"},"160":{"id":"/docs/features/orchestrator-6","page_id":"/docs/features/orchestrator","type":"heading","tags":[],"url":"/docs/features/orchestrator#start-the-run","content":"Start the run"},"161":{"id":"/docs/features/orchestrator-7","page_id":"/docs/features/orchestrator","type":"heading","tags":[],"url":"/docs/features/orchestrator#monitor-and-review","content":"Monitor and review"},"162":{"id":"/docs/features/orchestrator-8","page_id":"/docs/features/orchestrator","type":"heading","tags":[],"url":"/docs/features/orchestrator#task-states","content":"Task states"},"163":{"id":"/docs/features/orchestrator-9","page_id":"/docs/features/orchestrator","type":"heading","tags":[],"url":"/docs/features/orchestrator#concurrency","content":"Concurrency"},"164":{"id":"/docs/features/orchestrator-10","page_id":"/docs/features/orchestrator","type":"heading","tags":[],"url":"/docs/features/orchestrator#retries","content":"Retries"},"165":{"id":"/docs/features/orchestrator-11","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator","content":"The Orchestrator lets you run multiple AI agent sessions in parallel, coordinated by a plan. Instead of sending tasks to one agent at a time, you define a set of tasks and the orchestrator distributes them across concurrent agent sessions, tracks progress, and handles retries."},"166":{"id":"/docs/features/orchestrator-12","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#how-it-works","content":"The orchestrator follows a straightforward model:"},"167":{"id":"/docs/features/orchestrator-13","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#how-it-works","content":"**Define tasks** — describe what needs to be done, broken into independent units of work"},"168":{"id":"/docs/features/orchestrator-14","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#how-it-works","content":"**Create a run** — the orchestrator schedules tasks and assigns them to agent sessions"},"169":{"id":"/docs/features/orchestrator-15","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#how-it-works","content":"**Monitor progress** — watch as agents work in parallel, with real-time status updates"},"170":{"id":"/docs/features/orchestrator-16","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#how-it-works","content":"**Review results** — see what each agent accomplished when the run completes"},"171":{"id":"/docs/features/orchestrator-17","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#how-it-works","content":"Each task runs in its own agent chat session. The orchestrator manages the lifecycle — starting sessions, sending prompts, monitoring for completion, and handling failures with automatic retries."},"172":{"id":"/docs/features/orchestrator-18","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#use-cases","content":"**Large refactors**: Split a codebase-wide change into file-by-file or module-by-module tasks"},"173":{"id":"/docs/features/orchestrator-19","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#use-cases","content":"**Parallel code reviews**: Have multiple agents review different parts of a PR simultaneously"},"174":{"id":"/docs/features/orchestrator-20","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#use-cases","content":"**Batch operations**: Run the same type of task across many files or repositories"},"175":{"id":"/docs/features/orchestrator-21","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#use-cases","content":"**Testing campaigns**: Generate tests for multiple modules in parallel"},"176":{"id":"/docs/features/orchestrator-22","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#open-the-orchestrator","content":"Click &#x2A;*+** in the tab bar and select **Orchestrator**."},"177":{"id":"/docs/features/orchestrator-23","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#define-your-tasks","content":"Add tasks with descriptions of what each agent should do. Each task should be independent — agents work in parallel without knowledge of what other agents are doing."},"178":{"id":"/docs/features/orchestrator-24","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#start-the-run","content":"The orchestrator creates agent chat sessions for each task and begins execution. You can watch progress in real time."},"179":{"id":"/docs/features/orchestrator-25","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#monitor-and-review","content":"Each task shows its status: pending, running, completed, or failed. Failed tasks are retried automatically with exponential backoff."},"180":{"id":"/docs/features/orchestrator-26","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#monitor-and-review","content":"Tasks should be independent units of work. The orchestrator runs them in parallel, so tasks that depend on each other's output will not work well. Design your tasks so each agent can work without waiting for another."},"181":{"id":"/docs/features/orchestrator-27","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#task-states","content":"State"},"182":{"id":"/docs/features/orchestrator-28","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#task-states","content":"Meaning"},"183":{"id":"/docs/features/orchestrator-29","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#task-states","content":"Pending"},"184":{"id":"/docs/features/orchestrator-30","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#task-states","content":"Queued, waiting for an available agent session"},"185":{"id":"/docs/features/orchestrator-31","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#task-states","content":"Running"},"186":{"id":"/docs/features/orchestrator-32","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#task-states","content":"An agent is actively working on this task"},"187":{"id":"/docs/features/orchestrator-33","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#task-states","content":"Completed"},"188":{"id":"/docs/features/orchestrator-34","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#task-states","content":"The agent finished successfully"},"189":{"id":"/docs/features/orchestrator-35","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#task-states","content":"Failed"},"190":{"id":"/docs/features/orchestrator-36","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#task-states","content":"The task failed — will be retried up to the configured limit"},"191":{"id":"/docs/features/orchestrator-37","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#concurrency","content":"The orchestrator manages how many agent sessions run simultaneously. This prevents overwhelming your machine with too many concurrent CLI processes. Tasks that exceed the concurrency limit are queued and start as earlier tasks complete."},"192":{"id":"/docs/features/orchestrator-38","page_id":"/docs/features/orchestrator","tags":[],"type":"text","url":"/docs/features/orchestrator#retries","content":"When a task fails, the orchestrator retries it with exponential backoff. This handles transient issues like API rate limits or temporary network errors. You can configure the maximum number of retries per task."},"193":{"id":"/docs/features/projects","page_id":"/docs/features/projects","type":"page","content":"Projects","breadcrumbs":["Docs","Features"],"tags":[],"url":"/docs/features/projects"},"194":{"id":"/docs/features/projects-0","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects","content":"Organize terminals, editors, and agent chats into project workspaces."},"195":{"id":"/docs/features/projects-1","page_id":"/docs/features/projects","type":"heading","tags":[],"url":"/docs/features/projects#creating-a-project","content":"Creating a project"},"196":{"id":"/docs/features/projects-2","page_id":"/docs/features/projects","type":"heading","tags":[],"url":"/docs/features/projects#what-projects-contain","content":"What projects contain"},"197":{"id":"/docs/features/projects-3","page_id":"/docs/features/projects","type":"heading","tags":[],"url":"/docs/features/projects#working-directory","content":"Working directory"},"198":{"id":"/docs/features/projects-4","page_id":"/docs/features/projects","type":"heading","tags":[],"url":"/docs/features/projects#switching-between-projects","content":"Switching between projects"},"199":{"id":"/docs/features/projects-5","page_id":"/docs/features/projects","type":"heading","tags":[],"url":"/docs/features/projects#when-to-use-projects","content":"When to use projects"},"200":{"id":"/docs/features/projects-6","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects","content":"Projects let you group related sessions together. Instead of having a flat list of terminal tabs, editor tabs, and agent chats, you can organize them by project — keeping your frontend work separate from your backend work, or your personal projects separate from work."},"201":{"id":"/docs/features/projects-7","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects#creating-a-project","content":"Click &#x2A;*+** in the tab bar"},"202":{"id":"/docs/features/projects-8","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects#creating-a-project","content":"Select **Project**"},"203":{"id":"/docs/features/projects-9","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects#creating-a-project","content":"Choose a working directory for the project"},"204":{"id":"/docs/features/projects-10","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects#creating-a-project","content":"The project opens as a container tab. Inside it, you can create terminals, editors, and agent chats that are scoped to that project's directory."},"205":{"id":"/docs/features/projects-11","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects#what-projects-contain","content":"A project can hold:"},"206":{"id":"/docs/features/projects-12","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects#what-projects-contain","content":"**Terminals** that start in the project's working directory"},"207":{"id":"/docs/features/projects-13","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects#what-projects-contain","content":"**Agent chats** scoped to the project's codebase"},"208":{"id":"/docs/features/projects-14","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects#what-projects-contain","content":"**IDE tabs** that open the project's folder"},"209":{"id":"/docs/features/projects-15","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects#what-projects-contain","content":"**Web previews** for dev servers running in the project"},"210":{"id":"/docs/features/projects-16","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects#working-directory","content":"Every session created within a project inherits the project's working directory. When you open a new terminal inside a project, it starts in the project root. When you start an agent chat, the AI assistant has context about the project's files."},"211":{"id":"/docs/features/projects-17","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects#working-directory","content":"This means you do not need to `cd` into your project directory every time you open a new terminal — the project handles that for you."},"212":{"id":"/docs/features/projects-18","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects#switching-between-projects","content":"Projects appear as tabs in the main tab bar, just like terminals and editors. Click a project tab to switch to it and see its sessions."},"213":{"id":"/docs/features/projects-19","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects#switching-between-projects","content":"Projects are a local organizational tool. They do not create any files in your project directory or modify your repository in any way."},"214":{"id":"/docs/features/projects-20","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects#when-to-use-projects","content":"Projects are most useful when you are working on multiple codebases at once. Instead of managing a sea of unlabeled terminal tabs, you can group everything by context:"},"215":{"id":"/docs/features/projects-21","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects#when-to-use-projects","content":"**Monorepo work**: One project for the frontend, another for the backend, another for infrastructure"},"216":{"id":"/docs/features/projects-22","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects#when-to-use-projects","content":"**Multi-repo development**: Separate projects for related but distinct repositories"},"217":{"id":"/docs/features/projects-23","page_id":"/docs/features/projects","tags":[],"type":"text","url":"/docs/features/projects#when-to-use-projects","content":"**Context switching**: Keep your side project's sessions separate from your work sessions"},"218":{"id":"/docs/features/terminal","page_id":"/docs/features/terminal","type":"page","content":"Terminal","breadcrumbs":["Docs","Features"],"tags":[],"url":"/docs/features/terminal"},"219":{"id":"/docs/features/terminal-0","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal","content":"Full PTY terminal emulation with tabs, scrollback, and remote access."},"220":{"id":"/docs/features/terminal-1","page_id":"/docs/features/terminal","type":"heading","tags":[],"url":"/docs/features/terminal#local-terminals","content":"Local terminals"},"221":{"id":"/docs/features/terminal-2","page_id":"/docs/features/terminal","type":"heading","tags":[],"url":"/docs/features/terminal#what-works","content":"What works"},"222":{"id":"/docs/features/terminal-3","page_id":"/docs/features/terminal","type":"heading","tags":[],"url":"/docs/features/terminal#remote-terminals","content":"Remote terminals"},"223":{"id":"/docs/features/terminal-4","page_id":"/docs/features/terminal","type":"heading","tags":[],"url":"/docs/features/terminal#working-with-multiple-terminals","content":"Working with multiple terminals"},"224":{"id":"/docs/features/terminal-5","page_id":"/docs/features/terminal","type":"heading","tags":[],"url":"/docs/features/terminal#terminal-within-projects","content":"Terminal within projects"},"225":{"id":"/docs/features/terminal-6","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal","content":"Mate's terminal is a real PTY shell — not a simplified command runner. It uses full xterm emulation backed by a native PTY, so everything you expect from a terminal works: colors, cursor addressing, interactive programs, shell completion, and full Unicode support."},"226":{"id":"/docs/features/terminal-7","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#local-terminals","content":"A local terminal runs your default shell (zsh, bash, fish, or whatever you have configured) directly on the machine. Each terminal tab is an independent session with its own working directory and environment."},"227":{"id":"/docs/features/terminal-8","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#local-terminals","content":"You can open as many terminal tabs as you need. Each one is a separate shell process."},"228":{"id":"/docs/features/terminal-9","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#what-works","content":"Full ANSI color and formatting (256-color and truecolor)"},"229":{"id":"/docs/features/terminal-10","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#what-works","content":"Interactive programs: `vim`, `nano`, `top`, `htop`, `less`, and more"},"230":{"id":"/docs/features/terminal-11","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#what-works","content":"Shell features: tab completion, history, aliases, custom prompts"},"231":{"id":"/docs/features/terminal-12","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#what-works","content":"Mouse support in programs that use it"},"232":{"id":"/docs/features/terminal-13","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#what-works","content":"Scrollback buffer for reviewing previous output"},"233":{"id":"/docs/features/terminal-14","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#what-works","content":"Copy and paste with standard keyboard shortcuts"},"234":{"id":"/docs/features/terminal-15","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#remote-terminals","content":"When you select a paired remote device in the sidebar, terminal tabs show that device's sessions. Remote terminals connect over WebSocket and behave identically to local ones — same PTY, same scrollback, same interactive program support."},"235":{"id":"/docs/features/terminal-16","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#remote-terminals","content":"From a remote device (like your phone), you can:"},"236":{"id":"/docs/features/terminal-17","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#remote-terminals","content":"View and interact with terminals running on the desktop"},"237":{"id":"/docs/features/terminal-18","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#remote-terminals","content":"Create new terminal sessions on the desktop"},"238":{"id":"/docs/features/terminal-19","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#remote-terminals","content":"Use the same shell with full input support"},"239":{"id":"/docs/features/terminal-20","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#remote-terminals","content":"Remote terminal sessions are owned by the desktop. Creating a terminal from your phone actually creates it on the paired desktop — your phone is just the viewer and controller."},"240":{"id":"/docs/features/terminal-21","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#working-with-multiple-terminals","content":"The tab bar shows all open terminals. You can:"},"241":{"id":"/docs/features/terminal-22","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#working-with-multiple-terminals","content":"**Open** a new terminal with the + button or keyboard shortcut"},"242":{"id":"/docs/features/terminal-23","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#working-with-multiple-terminals","content":"**Switch** between terminals by clicking tabs or using keyboard shortcuts"},"243":{"id":"/docs/features/terminal-24","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#working-with-multiple-terminals","content":"**Reorder** tabs by dragging"},"244":{"id":"/docs/features/terminal-25","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#working-with-multiple-terminals","content":"**Close** a terminal by clicking the tab's X button"},"245":{"id":"/docs/features/terminal-26","page_id":"/docs/features/terminal","tags":[],"type":"text","url":"/docs/features/terminal#terminal-within-projects","content":"Terminals can be organized inside Projects. When you create a terminal within a project, it starts in the project's working directory and is grouped with the project's other sessions."},"246":{"id":"/docs/features/voice-input","page_id":"/docs/features/voice-input","type":"page","content":"Voice Input","breadcrumbs":["Docs","Features"],"tags":[],"url":"/docs/features/voice-input"},"247":{"id":"/docs/features/voice-input-0","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input","content":"Talk instead of type with built-in speech-to-text."},"248":{"id":"/docs/features/voice-input-1","page_id":"/docs/features/voice-input","type":"heading","tags":[],"url":"/docs/features/voice-input#stt-engines","content":"STT Engines"},"249":{"id":"/docs/features/voice-input-2","page_id":"/docs/features/voice-input","type":"heading","tags":[],"url":"/docs/features/voice-input#native","content":"Native"},"250":{"id":"/docs/features/voice-input-3","page_id":"/docs/features/voice-input","type":"heading","tags":[],"url":"/docs/features/voice-input#whisper","content":"Whisper"},"251":{"id":"/docs/features/voice-input-4","page_id":"/docs/features/voice-input","type":"heading","tags":[],"url":"/docs/features/voice-input#cloud-stt","content":"Cloud STT"},"252":{"id":"/docs/features/voice-input-5","page_id":"/docs/features/voice-input","type":"heading","tags":[],"url":"/docs/features/voice-input#azure-speech","content":"Azure Speech"},"253":{"id":"/docs/features/voice-input-6","page_id":"/docs/features/voice-input","type":"heading","tags":[],"url":"/docs/features/voice-input#how-to-use-it","content":"How to use it"},"254":{"id":"/docs/features/voice-input-7","page_id":"/docs/features/voice-input","type":"heading","tags":[],"url":"/docs/features/voice-input#open-an-agent-chat-tab","content":"Open an Agent Chat tab"},"255":{"id":"/docs/features/voice-input-8","page_id":"/docs/features/voice-input","type":"heading","tags":[],"url":"/docs/features/voice-input#tap-the-microphone-icon","content":"Tap the microphone icon"},"256":{"id":"/docs/features/voice-input-9","page_id":"/docs/features/voice-input","type":"heading","tags":[],"url":"/docs/features/voice-input#speak-your-message","content":"Speak your message"},"257":{"id":"/docs/features/voice-input-10","page_id":"/docs/features/voice-input","type":"heading","tags":[],"url":"/docs/features/voice-input#review-and-send","content":"Review and send"},"258":{"id":"/docs/features/voice-input-11","page_id":"/docs/features/voice-input","type":"heading","tags":[],"url":"/docs/features/voice-input#choosing-an-engine","content":"Choosing an engine"},"259":{"id":"/docs/features/voice-input-12","page_id":"/docs/features/voice-input","type":"heading","tags":[],"url":"/docs/features/voice-input#language-support","content":"Language support"},"260":{"id":"/docs/features/voice-input-13","page_id":"/docs/features/voice-input","type":"heading","tags":[],"url":"/docs/features/voice-input#platform-availability","content":"Platform availability"},"261":{"id":"/docs/features/voice-input-14","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input","content":"Voice Input adds speech-to-text to the agent chat composer. Instead of typing out a detailed prompt, tap the microphone icon and talk. Your speech gets transcribed into text in the composer, ready to send or edit before submitting."},"262":{"id":"/docs/features/voice-input-15","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input","content":"This is especially useful on mobile devices where typing long prompts is tedious, or when you are describing a problem and just want to think out loud."},"263":{"id":"/docs/features/voice-input-16","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"Mate supports four speech-to-text engines, each with different tradeoffs:"},"264":{"id":"/docs/features/voice-input-17","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"Engine"},"265":{"id":"/docs/features/voice-input-18","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"Runs locally?"},"266":{"id":"/docs/features/voice-input-19","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"Setup"},"267":{"id":"/docs/features/voice-input-20","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"Best for"},"268":{"id":"/docs/features/voice-input-21","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"Native"},"269":{"id":"/docs/features/voice-input-22","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"Yes"},"270":{"id":"/docs/features/voice-input-23","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"None"},"271":{"id":"/docs/features/voice-input-24","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"Quick dictation with zero setup"},"272":{"id":"/docs/features/voice-input-25","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"Whisper"},"273":{"id":"/docs/features/voice-input-26","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"Yes (after download)"},"274":{"id":"/docs/features/voice-input-27","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"One-time model download"},"275":{"id":"/docs/features/voice-input-28","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"Offline use, privacy-sensitive work"},"276":{"id":"/docs/features/voice-input-29","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"Cloud STT"},"277":{"id":"/docs/features/voice-input-30","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"No"},"278":{"id":"/docs/features/voice-input-31","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"API key"},"279":{"id":"/docs/features/voice-input-32","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"High accuracy, many languages"},"280":{"id":"/docs/features/voice-input-33","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"Azure Speech"},"281":{"id":"/docs/features/voice-input-34","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"No"},"282":{"id":"/docs/features/voice-input-35","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"API key"},"283":{"id":"/docs/features/voice-input-36","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#stt-engines","content":"Enterprise environments, Azure users"},"284":{"id":"/docs/features/voice-input-37","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#native","content":"Uses your platform's built-in speech recognition — Siri on Apple devices, Google Speech on Android. No setup required, works immediately. Accuracy depends on your platform's implementation, but it is solid for English and most major languages."},"285":{"id":"/docs/features/voice-input-38","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#whisper","content":"Runs OpenAI's Whisper model locally on your device. The first time you use it, Mate downloads the model (\\~150MB). After that, everything runs offline — no network requests, no API keys, no data leaving your machine."},"286":{"id":"/docs/features/voice-input-39","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#whisper","content":"Whisper handles accents and background noise well, and supports dozens of languages out of the box."},"287":{"id":"/docs/features/voice-input-40","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#cloud-stt","content":"Uses a cloud-based speech-to-text API for transcription. Requires an API key configured in Settings. Offers high accuracy and broad language support, with the tradeoff that audio is sent to an external service for processing."},"288":{"id":"/docs/features/voice-input-41","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#azure-speech","content":"Microsoft's Azure Speech Services. Requires an Azure subscription and speech resource key. A good fit if you are already in the Azure ecosystem or need enterprise-grade speech recognition with compliance guarantees."},"289":{"id":"/docs/features/voice-input-42","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#open-an-agent-chat-tab","content":"Voice input works in the agent chat composer — the text field where you type messages to the AI agent."},"290":{"id":"/docs/features/voice-input-43","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#tap-the-microphone-icon","content":"You will see a mic icon in the composer bar. Tap it to start recording. If this is your first time, Mate may ask for microphone permission."},"291":{"id":"/docs/features/voice-input-44","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#speak-your-message","content":"Talk naturally. The transcription appears in the composer as you speak. When you are done, tap the mic icon again to stop."},"292":{"id":"/docs/features/voice-input-45","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#review-and-send","content":"The transcribed text appears in the composer. Edit it if needed, then send it to the agent like any other message."},"293":{"id":"/docs/features/voice-input-46","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#choosing-an-engine","content":"Open **Settings** and look for the **Speech-to-Text** section. You can select your preferred engine and configure any required credentials. The engine selection persists across sessions."},"294":{"id":"/docs/features/voice-input-47","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#choosing-an-engine","content":"If you want fully offline voice input with no setup beyond the initial download, Whisper is the way to go. For zero-setup convenience, start with Native and switch later if you need better accuracy."},"295":{"id":"/docs/features/voice-input-48","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#language-support","content":"All four engines support multiple languages. The available languages depend on the engine:"},"296":{"id":"/docs/features/voice-input-49","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#language-support","content":"**Native**: Whatever your OS supports — typically 30+ languages on modern devices"},"297":{"id":"/docs/features/voice-input-50","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#language-support","content":"**Whisper**: 99 languages (full list on OpenAI's Whisper documentation)"},"298":{"id":"/docs/features/voice-input-51","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#language-support","content":"**Cloud STT**: Varies by provider, typically 50+ languages"},"299":{"id":"/docs/features/voice-input-52","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#language-support","content":"**Azure Speech**: 100+ languages and variants"},"300":{"id":"/docs/features/voice-input-53","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#language-support","content":"English variants (US, UK, Australian, etc.) are supported across all engines."},"301":{"id":"/docs/features/voice-input-54","page_id":"/docs/features/voice-input","tags":[],"type":"text","url":"/docs/features/voice-input#platform-availability","content":"Voice input works on all platforms where Mate runs: macOS, Windows, Linux, Android, and iOS. The Native engine uses platform-specific APIs, so the experience varies slightly — Siri's speech recognition on Apple devices, Google's on Android, and platform speech APIs on desktop. Whisper, Cloud STT, and Azure Speech behave identically across all platforms."},"302":{"id":"/docs/features/web-preview","page_id":"/docs/features/web-preview","type":"page","content":"Web Preview","breadcrumbs":["Docs","Features"],"tags":[],"url":"/docs/features/web-preview"},"303":{"id":"/docs/features/web-preview-0","page_id":"/docs/features/web-preview","tags":[],"type":"text","url":"/docs/features/web-preview","content":"Preview localhost web apps from any paired device through a built-in reverse proxy."},"304":{"id":"/docs/features/web-preview-1","page_id":"/docs/features/web-preview","type":"heading","tags":[],"url":"/docs/features/web-preview#how-it-works","content":"How it works"},"305":{"id":"/docs/features/web-preview-2","page_id":"/docs/features/web-preview","type":"heading","tags":[],"url":"/docs/features/web-preview#opening-a-web-preview","content":"Opening a web preview"},"306":{"id":"/docs/features/web-preview-3","page_id":"/docs/features/web-preview","type":"heading","tags":[],"url":"/docs/features/web-preview#use-cases","content":"Use cases"},"307":{"id":"/docs/features/web-preview-4","page_id":"/docs/features/web-preview","type":"heading","tags":[],"url":"/docs/features/web-preview#live-reloading","content":"Live reloading"},"308":{"id":"/docs/features/web-preview-5","page_id":"/docs/features/web-preview","type":"heading","tags":[],"url":"/docs/features/web-preview#limitations","content":"Limitations"},"309":{"id":"/docs/features/web-preview-6","page_id":"/docs/features/web-preview","tags":[],"type":"text","url":"/docs/features/web-preview","content":"Web Preview lets you view web applications running on one device from another device on your network. If your dev server is running on `localhost:3000` on your Mac, you can see it on your phone without any port forwarding or tunneling setup."},"310":{"id":"/docs/features/web-preview-7","page_id":"/docs/features/web-preview","tags":[],"type":"text","url":"/docs/features/web-preview#how-it-works","content":"Mate runs a reverse proxy that forwards HTTP requests from the viewing device to the target device's localhost port. The web content is rendered in an embedded browser view within Mate."},"311":{"id":"/docs/features/web-preview-8","page_id":"/docs/features/web-preview","tags":[],"type":"text","url":"/docs/features/web-preview#how-it-works","content":"Thi